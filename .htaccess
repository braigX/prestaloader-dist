Options -MultiViews

<IfModule mod_rewrite.c>
  RewriteEngine On
  RewriteBase /

  RewriteCond %{REQUEST_FILENAME} -f [OR]
  RewriteCond %{REQUEST_FILENAME} -d
  RewriteRule ^ - [L]

  RewriteRule ^assets/ - [R=404,L]
  RewriteRule \.(js|mjs|css|map|json|png|jpg|jpeg|gif|svg|webp|avif|woff|woff2|ttf|ico)$ - [R=404,L,NC]

  RewriteRule ^ index.html [L]
</IfModule>

<IfModule mod_headers.c>
  <FilesMatch "^index\.html$">
    Header always set Cache-Control "no-store, no-cache, must-revalidate, max-age=0"
    Header always set Pragma "no-cache"
    Header always set Expires "0"
  </FilesMatch>

  <FilesMatch "^favicon\.ico$">
    Header always set Cache-Control "public, max-age=86400"
  </FilesMatch>

  <FilesMatch "\.(js|mjs|css|map|png|jpg|jpeg|gif|svg|webp|avif|woff|woff2|ttf|ico)$">
    Header always set Cache-Control "public, max-age=31536000, immutable"
  </FilesMatch>
</IfModule>

<IfModule mod_mime.c>
  AddType text/javascript .js .mjs
  AddType text/css .css
</IfModule>
